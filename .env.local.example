# Per-user env loaded by direnv (see .envrc) and `cargo xtask`
# (via figment). Copy to .env.local and edit. Gitignored.
AWS_PROFILE=beme_sandbox

# k8s provider for `cargo xtask k8s ...`. If set, you can omit -p.
# Valid: kind (fast local iteration), k3s (local+Rook), eks (AWS).
RIO_K8S_PROVIDER=kind

# State bucket — defaults to rio-tfstate-${account_id} (computed
# from `aws sts get-caller-identity`). Override if you used a
# custom name or the pattern doesn't hold for your account.
# RIO_TFSTATE_BUCKET=my-custom-tfstate-bucket

# State bucket region — defaults to us-east-2.
# RIO_TFSTATE_REGION=us-east-2

# SSH public key for gateway authorized_keys. Used by both
# `cargo xtask k8s up -p k3s` (local k3s/kind) and `cargo xtask k8s deploy -p eks`.
# The key's comment is STRIPPED → single-tenant mode (builds work
# with zero tenant setup). Default: ~/.ssh/id_ed25519.pub
# RIO_SSH_PUBKEY=~/.ssh/id_ed25519.pub

# If set, use this as the authorized_keys comment instead of stripping.
# The gateway maps comment → tenant_name; the scheduler requires that
# tenant to exist. Create it first:
#   kubectl -n rio-system exec deploy/rio-scheduler -- rio-cli create-tenant <name>
# RIO_SSH_TENANT=my-team
