# SPDX-License-Identifier: EUPL-1.2

# Our schema shims don't work properly with 'database setup' and 'database reset' :(
if test "$argv[1]" = "database"
    echo "The 'diesel database' subcommands don't work with our wrapper. :("
    exit 1
end

# Move to the parent directorhy, so diesel will find ./diesel.toml and ./migrations.
cd (dirname (status dirname))
echo "$(set_color --dim)📂 Running diesel in: $(pwd)$(set_color normal)"

# Use the directory name (eg. "gorgond") as the schema we're working with.
set -l SCHEMA (string replace -a - _ (path basename (pwd)))
echo "$(set_color --dim)🗄️ Using Schema: $SCHEMA$(set_color normal)"

# Diesel migrations always use the default schema, so we need to overwrite search_path
# to force it to put the __diesel_schema_migrations table in the right place.
set -x DATABASE_URL $GORGOND_DATABASE_URL&options=-csearch_path%3D$SCHEMA
echo "$(set_color --dim)📡 DATABASE_URL: $DATABASE_URL$(set_color normal)"

# Create the schema before proceeding.
set_color --dim
echo "📁 Creating schema..."
psql -a $DATABASE_URL -c "CREATE SCHEMA IF NOT EXISTS $SCHEMA"
set_color normal

# Invoke the actual diesel CLI.
set -q DIESEL; or set -x DIESEL (command -s diesel)
exec $DIESEL $argv
