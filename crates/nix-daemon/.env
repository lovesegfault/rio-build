# Connect to Postgres started by `process-compose`.
export PGDATA=$PWD/.direnv/pg/data
export PGHOST=$PWD/.direnv/pg
export PGDATABASE=gorgon
export GORGOND_DATABASE_URL=postgres:///$PGDATABASE?host=$PGHOST

# Store event log files in ./data/events/.
export GORGON_EVENT_STORE_URL=file://$PWD/data/events/
export GORGON_EVENT_BASE_URL=file://$PWD/data/events/
