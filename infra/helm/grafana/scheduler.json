{
  "uid": "rio-scheduler",
  "title": "rio-build: Scheduler",
  "tags": ["rio-build"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Assignment latency p50/p99",
      "description": "Time from ready to assigned. Scheduler dispatch efficiency.",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(rio_scheduler_assignment_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(rio_scheduler_assignment_latency_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ready queue depth",
      "description": "Derivations waiting for assignment.",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rio_scheduler_derivations_queued",
          "legendFormat": "queued",
          "refId": "A"
        },
        {
          "expr": "rio_scheduler_derivations_running",
          "legendFormat": "running",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Backstop timeouts",
      "description": "Running derivations reset to Ready after exceeding backstop timeout. Non-zero indicates wedged workers.",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(rio_scheduler_backstop_timeouts_total[5m]))",
          "legendFormat": "timeouts/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.001}]},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cancel signals",
      "description": "CancelSignal messages sent to workers (explicit CancelBuild, backstop timeout, or finalizer drain).",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(rio_scheduler_cancel_signals_total[5m]))",
          "legendFormat": "cancels/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Misclassifications (penalty)",
      "description": "Builds that exceeded 2x their class cutoff duration, triggering penalty EMA overwrite.",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(rio_scheduler_misclassifications_total[5m]))",
          "legendFormat": "misclass/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Class drift (cutoff)",
      "description": "Post-hoc classification drift: classify(actual) != assigned. Populated after P0228 completion-samples counter merges; shows No Data until then.",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum by (assigned_class, actual_class) (rate(rio_scheduler_class_drift_total[5m]))",
          "legendFormat": "{{assigned_class}} -> {{actual_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    }
  ]
}
