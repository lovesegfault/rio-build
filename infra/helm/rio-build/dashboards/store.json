{
  "uid": "rio-store",
  "title": "rio-build: Store",
  "tags": ["rio-build", "store"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PutPath latency p50/p99",
      "description": "rio_store_put_path_duration_seconds — end-to-end PutPath (NAR ingest + chunk + S3 + PG commit).",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(rio_store_put_path_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(rio_store_put_path_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PG pool utilization",
      "description": "rio_store_pg_pool_utilization — fraction of sqlx connection pool in use. Sustained > 0.9 = pool-starved; PutPath/QueryPath start queueing.",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rio_store_pg_pool_utilization",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          },
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "PutPath retries",
      "description": "rate(rio_store_putpath_retries_total[5m]) — serialization-conflict / transient-error retries on the PutPath path. (Metric lands in P0539d; shows No Data until then.)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(rio_store_putpath_retries_total[5m]))",
          "legendFormat": "retries/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC sweep paths remaining",
      "description": "rio_store_gc_sweep_paths_remaining — paths still to scan in the current GC sweep. Sawtooth = healthy; flat non-zero = sweep stuck. (Metric lands in P0539d; shows No Data until then.)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rio_store_gc_sweep_paths_remaining",
          "legendFormat": "remaining",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "spanNulls": false}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PutPath throughput",
      "description": "rate(rio_store_put_path_total[1m]) and rate(rio_store_put_path_bytes_total[1m]).",
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(rio_store_put_path_total[1m]))",
          "legendFormat": "paths/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rio_store_put_path_bytes_total[1m]))",
          "legendFormat": "bytes/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "spanNulls": false}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "bytes/s"},
            "properties": [
              {"id": "unit", "value": "Bps"},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    }
  ]
}
