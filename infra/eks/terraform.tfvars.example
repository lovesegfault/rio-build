# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.
#
# Most defaults are fine for beme_sandbox dev. Override here if
# your account/region/naming differs.

# region = "us-east-2"          # default

# cluster_name = "rio-build"    # default. Must be lowercase,
#                               # hyphens only, start with a letter
#                               # (used in S3 bucket + RDS names).
#                               # Change if you're deploying a
#                               # second rio cluster in the same
#                               # account.

# kubernetes_version and the addon chart versions (cert_manager_version,
# aws_lbc_version, karpenter_version) are sourced from
# generated.auto.tfvars.json — regenerate with:
#   nix build .#tfvars && jq -S . result > infra/eks/generated.auto.tfvars.json
# Override here only for a hotfix; *.auto.tfvars.json loads AFTER
# terraform.tfvars so the generated values win unless you delete that file.

# System node sizing (scheduler/store/gateway/controller).
# system_instance_type  = "m5.large"
#
# Worker nodes are Karpenter-provisioned — instance families and
# limits are configured per-NodePool in the chart (values.yaml
# karpenter.nodePools), not here.
