# Ignore build outputs from performing a nix-build or `nix build` command
result
result-*

# Ignore automatically generated direnv output
.direnv

# Per-user env (AWS_PROFILE etc) — see .env.local.example
.env.local

# Written by `cargo xtask k8s push`, read by `k8s deploy`. Carries the
# dirty suffix between push and deploy. NEVER committed — private ECR,
# tags are meaningless outside one AWS account.
.rio-image-tag
# Same, for the NixOS node AMI (ADR-021): `xtask k8s ami push` writes
# the tagged SHA, `k8s deploy` reads it for EC2NodeClass amiSelector.
.rio-ami-tag

# Repo-local kubeconfig — `cargo xtask k8s kubeconfig` writes here
# instead of polluting ~/.kube/config. xtask sets KUBECONFIG to this
# path so kube-rs/helm/kubectl all pick it up.
.kube/

# Subchart symlinks from nix/helm-charts.nix (pre-commit hook creates them).
infra/helm/rio-build/charts/

# tofu providers come from opentofu.withPlugins (nix-pinned) — the HCL
# lock file is regenerated by `tofu init` but nix is the source of truth.
infra/eks/.terraform.lock.hcl
infra/eks/bootstrap/.terraform.lock.hcl

# Pre-commit hooks
.pre-commit-config.yaml

# Rust
target/
**/*.rs.bk
*.pdb

# Python bytecode (nix/tests/lib/assertions.py is source-only)
__pycache__/
.pytest_cache/
.ruff_cache/

# mdbook output
docs/book/

# Dashboard build artifacts (rio-dashboard/.gitignore also has these;
# repo-root entries guard against `pnpm install` run from the wrong cwd).
rio-dashboard/node_modules/
rio-dashboard/dist/

.claude/settings.local.json
.claude/scheduled_tasks.lock

# DAG-runner runtime state (agents-running.jsonl, merge-queue.jsonl, etc.)
.claude/state/
.claude/lib/.pytest_cache/
# write_jsonl crash artifact (tmp+rename — crash leaves .tmp sibling)
.claude/*.jsonl.tmp

# tracey daemon state (unix socket, cache)
.tracey/

# cargo-mutants output (`just mutants` runs --in-place against $PWD)
mutants.out*/

# Local dev runtime state (postgres data, gateway keys)
.data/
*.qcow2
.stress-test/
.claude/worktrees/
