use flake

# Local dev state
PRJ_DATA_DIR="$(pwd)/.data"
mkdir -p "$PRJ_DATA_DIR"

# PostgreSQL
export PGDATA="$PRJ_DATA_DIR/postgres"
export PGHOST="$PRJ_DATA_DIR"
export PGPORT="5434"
export PGLISTEN="127.0.0.1"
export PGUSER="rio"
export PGPASS="rio"
export PGDATABASE="rio_dev"
export DATABASE_URL="postgres://$PGUSER:$PGPASS@localhost:$PGPORT/$PGDATABASE"

# rio-store picks this up via figment (RIO_ prefix)
export RIO_DATABASE_URL="$DATABASE_URL"
