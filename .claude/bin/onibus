#!/usr/bin/env python3
"""onibus entrypoint. REPO_ROOT resolves per-worktree via __file__.

Invoke as `.claude/bin/onibus <group> <cmd> [args]` from the worktree root.
Same relative-invocation semantics as the old `python3 .claude/lib/state.py`.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))
from onibus.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
